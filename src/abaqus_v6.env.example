# Abaqus MCP auto-load configuration.
#
# Copy this file to:
#   Windows: C:\Users\YourUsername\abaqus_v6.env
#   Linux:   ~/abaqus_v6.env
#
# Then edit ABAQUS_MCP_HOME to your local Codex_MCP_Abaqus project path.

import os

os.environ["ABAQUS_MCP_HOME"] = r"D:\path\to\Codex_MCP_Abaqus"


def onCaeStartup():
    """Called when Abaqus/CAE starts."""
    mcp_plugin = os.path.join(
        os.environ["ABAQUS_MCP_HOME"],
        "src",
        "abaqus_mcp_plugin.py",
    )
    if os.path.exists(mcp_plugin):
        import __main__
        with open(mcp_plugin, "r") as f:
            exec(f.read(), __main__.__dict__)
